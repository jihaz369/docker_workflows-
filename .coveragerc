[run]
source = app
branch = True
omit =
    */tests/*
    */venv/*
    */__init__.py

[report]
show_missing = True
skip_covered = False
fail_under = 90
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    pass

[html]
directory = htmlcov

[xml]
output = coverage.xml
